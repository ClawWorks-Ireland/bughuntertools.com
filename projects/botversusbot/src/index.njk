<section>
    <h2>Latest Articles</h2>

    {# ME4: Featured article hero — most recent post #}
    {% set featuredPost = collections.articles | sort(reverse=true, attribute="date") | first %}
    {% if featuredPost %}
    <a href="{{ featuredPost.url }}" class="featured-article">
        <span class="featured-label">⭐ Latest</span>
        <h3>{{ featuredPost.data.title }}</h3>
        <p class="featured-meta">{{ featuredPost.date | date('MMMM d, yyyy') }}</p>
        <p class="featured-desc">{{ featuredPost.data.description }}</p>
        <span class="btn">Read Article →</span>
    </a>
    {% endif %}

    {# Remaining articles as standard list items #}
    <ul class="article-list">
        {%- for post in collections.articles | sort(reverse=true, attribute="date") | limit(5) -%}
        {% if not loop.first %}
        <li>
            <a href="{{ post.url }}">{{ post.data.title }}</a>
            <span class="date"> — <time datetime="{{ post.date | date('yyyy-MM-dd') }}">{{ post.date | date('MMMM d, yyyy') }}</time></span>
            {% if post.data.description %}<p>{{ post.data.description }}</p>{% endif %}
        </li>
        {% endif %}
        {%- endfor -%}
    </ul>
    <p><a href="/articles/">View all articles →</a></p>
</section>
