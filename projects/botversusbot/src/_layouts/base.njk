<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ description }}">
    <title>{{ title }}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href="https://botversusbot.com{{ page.url }}">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="article">
    <meta property="og:url" content="https://botversusbot.com{{ page.url }}">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ description }}">
    <meta property="og:site_name" content="Bot vs Bot">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="https://botversusbot.com{{ page.url }}">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ description }}">

    <link rel="stylesheet" href="/css/style.css">

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-1GBCTYR3XZ"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-1GBCTYR3XZ');
    </script>

    <!-- Google AdSense -->
    {% if site.adsense_enabled and site.adsense_pub_id %}
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client={{ site.adsense_pub_id }}" crossorigin="anonymous"></script>
    {% endif %}

    <!-- Schema.org markup -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "{{ schemaType | default('WebPage') }}",
      "name": "{{ title }}",
      "description": "{{ description }}",
      "url": "https://botversusbot.com{{ page.url }}"
    }
    </script>
</head>
<body>
    <header>
        <div class="container">
            <h1>🤖 <a href="/" style="color: white; text-decoration: none;">Bot vs Bot</a></h1>
            <p class="tagline">The CoinClaw Competition — AI Trading Bots, Head to Head</p>
            {% include "nav.njk" %}
        </div>
    </header>

    {% if page.url.startsWith('/articles/') and page.url != '/articles/' %}
    <nav class="breadcrumb" aria-label="Breadcrumb">
        <div class="container">
            <ol itemscope itemtype="https://schema.org/BreadcrumbList">
                <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                    <a itemprop="item" href="/"><span itemprop="name">Home</span></a>
                    <meta itemprop="position" content="1" />
                </li>
                <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                    <a itemprop="item" href="/articles/"><span itemprop="name">Articles</span></a>
                    <meta itemprop="position" content="2" />
                </li>
                <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                    <span itemprop="name">{{ title }}</span>
                    <meta itemprop="position" content="3" />
                </li>
            </ol>
        </div>
    </nav>
    {% endif %}

    <main class="container">
        {{ content | safe }}

        {% if site.adsense_enabled and site.adsense_pub_id and site.adsense_article_slot %}
        {% if page.url.startsWith('/articles/') and page.url != '/articles/' %}
        <div class="ad-container ad-below-article">
            <p class="ad-label">Advertisement</p>
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-client="{{ site.adsense_pub_id }}"
                 data-ad-slot="{{ site.adsense_article_slot }}"
                 data-ad-format="auto"
                 data-full-width-responsive="true"></ins>
            <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
        {% endif %}
        {% endif %}
    </main>

    <footer>
        <div class="container">
            <p>&copy; 2026 Bot vs Bot. All rights reserved. | <a href="/privacy/" style="color: white;">Privacy Policy</a></p>
        </div>
    </footer>
</body>
</html>
